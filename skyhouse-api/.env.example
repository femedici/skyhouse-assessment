# Copy this file to ".env" and fill in your key, then run: npm run dev
#
# Free GNews API key (100 requests/day): https://gnews.io/  -> sign up -> dashboard
GNEWS_API_KEY=your_gnews_api_key_here

# Optional: override the default search topic for the Insights tab.
# GNEWS_QUERY="performance marketing" OR "digital advertising" OR "ad spend" OR "paid media" OR "return on ad spend" OR "advertising campaign" OR "campaign performance" OR "marketing ROI"

# Optional: override the server port (defaults to 3000).
# PORT=3000
